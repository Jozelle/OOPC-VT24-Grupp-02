<Window x:Class="CarService.PresentationLayer.WPF.Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarService.PresentationLayer.WPF"
        mc:Ignorable="d"
        
        Title="MainWindow" Height="500" Width="739"
        MinHeight="500" MinWidth="800" WindowStartupLocation="CenterScreen">

    <DockPanel LastChildFill="True">
        <StackPanel Width="302">

            <Button x:Name="btnCreateBooking" Content="Create booking" FontSize="14" Width="200" Height="50"
                Margin="10,30,10,15" Click="btnSelectDate_Click"/>
            
            <Button x:Name="btnSearchBooking" Content="Search booking" FontSize="14" Width="200" Height="50"
                Margin="10,10,10,15" Click="btnCustomer_Click"/>
            
            <Button x:Name="btnSubmission" Content="Submission" FontSize="14" Width="200" Height="50"
                Margin="10,10,10,15" Click="btnVehicle_Click"/>
            
            <Button x:Name="btnPickUpAndPayment" Content="Pick up and Payment" FontSize="14" Width="200" Height="50"
                Margin="10,10,10,15" Click="btnSave_Click"/>
            
            <Button x:Name="btnClose" Content="Close" FontSize="14" Width="200" Height="50"
                 Margin="10,10,10,15" Click="btnSave_Click"/>
        </StackPanel>


        <StackPanel Width="498">
            <Border BorderBrush="Black" BorderThickness="6" Height="484" Width="499">
                
                <TextBox TextWrapping="Wrap" Margin="10,118,10,332" Text="TextBox"/>
                
            </Border>
        </StackPanel>
    </DockPanel>



</Window>
