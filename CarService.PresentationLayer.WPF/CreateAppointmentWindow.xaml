<Window x:Class="CarService.PresentationLayer.WPF.CreateAppointmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarService.PresentationLayer.WPF"
        mc:Ignorable="d"
        Title="CreateAppointmentWindow" Height="500" Width="800"
        MinHeight="500" MinWidth="800" WindowStartupLocation="CenterScreen">
    <DockPanel LastChildFill="True">
        <StackPanel Width="302">
        
            <Button x:Name="btnSelectDate" Content="Select date" FontSize="14" Width="200" Height="50"
        Margin="10,30,10,15" Click="btnCreate_Click"/>
            <Button x:Name="btnSearchCustomer" Content="Search customer" FontSize="14" Width="200" Height="50"
        Margin="10,10,10,15" Click="btnSearch_Click"/>
            <Button x:Name="btnSearchVehicle" Content="Search vehicle" FontSize="14" Width="200" Height="50"
        Margin="10,10,10,15" Click="btnSubmission_Click"/>
           
        </StackPanel>
        <StackPanel Width="498"/>
    </DockPanel>


</Window>