<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Primary colors -->
    <Color x:Key="primaryColorDark">#863852</Color>
    <Color x:Key="primaryColorMedium">#FFC1587B</Color>
    <Color x:Key="primaryColorLight">pink</Color>
    <Color x:Key="primaryColorWhite">LavenderBlush</Color>

    <!--Solid colors-->
    <SolidColorBrush x:Key="primaryColorDarkBrush">#863852</SolidColorBrush>
    <SolidColorBrush x:Key="primaryColorMediumBrush">#FFC1587B</SolidColorBrush>
    <SolidColorBrush x:Key="primaryColorLightBrush">pink</SolidColorBrush>
    <SolidColorBrush x:Key="primaryColorWhiteBrush">LavenderBlush</SolidColorBrush>
    
    <!--Gradients-->
    <LinearGradientBrush x:Key="threeColorGradientBrush"
                         StartPoint="0,0"
                         EndPoint="1,1">
        <GradientStop Color="{StaticResource primaryColorMedium}" Offset="0"/>
        <GradientStop Color="{StaticResource primaryColorLight}" Offset="0.5"/>
        <GradientStop Color="{StaticResource primaryColorMedium}" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>