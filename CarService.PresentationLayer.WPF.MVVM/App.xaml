<Application x:Class="CarService.PresentationLayer.WPF.MVVM.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CarService.PresentationLayer.WPF.MVVM"
             xmlns:views="clr-namespace:CarService.PresentationLayer.WPF.MVVM.Views"
             xmlns:viewmodels="clr-namespace:CarService.PresentationLayer.WPF.MVVM.ViewModels"
             StartupUri="Views/LoginView.xaml">
    <Application.Resources>
        <DataTemplate DataType="{x:Type viewmodels:MechanicViewModel }">
            <views:MechanicView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:JournalViewModel }">
            <views:Journal/>
        </DataTemplate>
    </Application.Resources>
</Application>
